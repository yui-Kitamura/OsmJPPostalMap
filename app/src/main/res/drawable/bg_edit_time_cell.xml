<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 枠線 (青) -->
    <item android:id="@+id/cell_border">
        <shape android:shape="rectangle">
            <solid android:color="@color/blue_frame" />
        </shape>
    </item>
    <!-- メイン背景 -->
    <item android:id="@+id/cell_background"
        android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/gray_bg" />
        </shape>
    </item>
</layer-list>