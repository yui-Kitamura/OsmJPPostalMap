<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back_postbox"
        android:contentDescription="戻る" />

    <ScrollView
        android:id="@+id/add_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="新規ポストの追加"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1. 地図"
            android:layout_marginBottom="8dp" />

        <org.osmdroid.views.MapView
            android:id="@+id/add_map"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2. 形状"
            android:layout_marginBottom="4dp" />

        <RadioGroup
            android:id="@+id/radio_shape"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <RadioButton
                android:id="@+id/shape_box"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="柱上箱型"
                android:checked="true" />
            <RadioButton
                android:id="@+id/shape_pillar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="円柱" />
            <RadioButton
                android:id="@+id/shape_other"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="その他" />
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3. 収集局名"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="収集局名 (任意)"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_branch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ポスト番号 (任意)"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_ref"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4. 時刻入力"
            android:layout_marginBottom="8dp" />

        <TableLayout
            android:id="@+id/table_collection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="0,1,2"
            android:layout_marginBottom="8dp">
            <TableRow>
                <TextView android:text="平日" android:gravity="center" android:textStyle="bold" android:padding="4dp"/>
                <TextView android:text="土曜" android:gravity="center" android:textStyle="bold" android:padding="4dp"/>
                <TextView android:text="日祝" android:gravity="center" android:textStyle="bold" android:padding="4dp"/>
            </TableRow>
            <TableRow>
                <Button
                    android:id="@+id/btn_copy_to_sat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="→土曜"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textSize="12sp" />
                <Button
                    android:id="@+id/btn_copy_to_sun"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="→日祝"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textSize="12sp" />
                <View android:layout_width="0dp" android:layout_height="0dp" />
            </TableRow>
            <!-- 行はプログラムから動的に追加する -->
        </TableLayout>

        <Button
            android:id="@+id/btn_add_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="行を追加"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="特殊な収集パターン (任意)"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btn_add_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="この内容で追加" />

    </LinearLayout>
    </ScrollView>
</LinearLayout>
