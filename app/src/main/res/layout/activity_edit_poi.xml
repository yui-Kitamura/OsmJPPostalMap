<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back_postbox"
        android:contentDescription="戻る" />

    <ScrollView
        android:id="@+id/edit_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

        <TextView
            android:id="@+id/edit_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <org.osmdroid.views.MapView
            android:id="@+id/edit_map"
            android:layout_width="match_parent"
            android:layout_height="200dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="-16dp"
            android:layout_marginBottom="16dp"
            android:background="#80FFFFFF"
            android:paddingHorizontal="4dp"
            android:paddingVertical="2dp"
            android:text="@string/osm_copyright"
            android:textColor="#000000"
            android:textSize="10sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/edit_tag_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="営業時間 (タグ直接編集)"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_tag_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:id="@+id/layout_opening_hours_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TableLayout
                android:id="@+id/table_opening_hours"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="1,2,3"
                android:layout_marginBottom="8dp">
                <TableRow>
                    <TextView android:text="" android:padding="4dp"/>
                    <TextView android:text="開店" android:gravity="center" android:textStyle="bold" android:padding="4dp"/>
                    <TextView android:text="閉店" android:gravity="center" android:textStyle="bold" android:padding="4dp"/>
                    <TextView android:text="休憩 (開始-終了)" android:gravity="center" android:textStyle="bold" android:padding="4dp"/>
                    <TextView android:text="休" android:gravity="center" android:textStyle="bold" android:padding="4dp"/>
                </TableRow>
                <TableRow>
                    <TextView android:text="平日" android:textStyle="bold" android:padding="4dp" android:gravity="center_vertical"/>
                    <EditText android:id="@+id/edit_oh_wd_open" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="09:00" android:inputType="time" android:background="@drawable/bg_edit_time_cell" android:padding="8dp" android:textSize="14sp" android:gravity="center"/>
                    <EditText android:id="@+id/edit_oh_wd_close" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="17:00" android:inputType="time" android:background="@drawable/bg_edit_time_cell" android:padding="8dp" android:textSize="14sp" android:gravity="center"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <EditText android:id="@+id/edit_oh_wd_break_start" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:hint="12:00" android:inputType="time" android:background="@drawable/bg_edit_time_cell" android:padding="8dp" android:textSize="12sp" android:gravity="center"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:padding="2dp"/>
                        <EditText android:id="@+id/edit_oh_wd_break_end" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:hint="13:00" android:inputType="time" android:background="@drawable/bg_edit_time_cell" android:padding="8dp" android:textSize="12sp" android:gravity="center"/>
                    </LinearLayout>
                    <CheckBox android:id="@+id/check_oh_wd_off" android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center"/>
                </TableRow>
                <TableRow android:layout_marginTop="4dp">
                    <TextView android:text="土曜" android:textStyle="bold" android:padding="4dp" android:gravity="center_vertical"/>
                    <EditText android:id="@+id/edit_oh_sa_open" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="09:00" android:inputType="time" android:background="@drawable/bg_edit_time_cell" android:padding="8dp" android:textSize="14sp" android:gravity="center"/>
                    <EditText android:id="@+id/edit_oh_sa_close" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="17:00" android:inputType="time" android:background="@drawable/bg_edit_time_cell" android:padding="8dp" android:textSize="14sp" android:gravity="center"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <EditText android:id="@+id/edit_oh_sa_break_start" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:hint="12:00" android:inputType="time" android:background="@drawable/bg_edit_time_cell" android:padding="8dp" android:textSize="12sp" android:gravity="center"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:padding="2dp"/>
                        <EditText android:id="@+id/edit_oh_sa_break_end" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:hint="13:00" android:inputType="time" android:background="@drawable/bg_edit_time_cell" android:padding="8dp" android:textSize="12sp" android:gravity="center"/>
                    </LinearLayout>
                    <CheckBox android:id="@+id/check_oh_sa_off" android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center"/>
                </TableRow>
                <TableRow android:layout_marginTop="4dp">
                    <TextView android:text="日祝" android:textStyle="bold" android:padding="4dp" android:gravity="center_vertical"/>
                    <EditText android:id="@+id/edit_oh_ph_open" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="09:00" android:inputType="time" android:background="@drawable/bg_edit_time_cell" android:padding="8dp" android:textSize="14sp" android:gravity="center"/>
                    <EditText android:id="@+id/edit_oh_ph_close" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="17:00" android:inputType="time" android:background="@drawable/bg_edit_time_cell" android:padding="8dp" android:textSize="14sp" android:gravity="center"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <EditText android:id="@+id/edit_oh_ph_break_start" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:hint="12:00" android:inputType="time" android:background="@drawable/bg_edit_time_cell" android:padding="8dp" android:textSize="12sp" android:gravity="center"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:padding="2dp"/>
                        <EditText android:id="@+id/edit_oh_ph_break_end" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:hint="13:00" android:inputType="time" android:background="@drawable/bg_edit_time_cell" android:padding="8dp" android:textSize="12sp" android:gravity="center"/>
                    </LinearLayout>
                    <CheckBox android:id="@+id/check_oh_ph_off" android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center"/>
                </TableRow>
            </TableLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <Button
                    android:id="@+id/btn_oh_copy_to_sa"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="平日→土曜"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textSize="12sp" />
                <Button
                    android:id="@+id/btn_oh_copy_to_ph"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="平日→日祝"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_collection_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TableLayout
                android:id="@+id/table_collection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="0,1,2"
                android:layout_marginBottom="8dp">
                <TableRow>
                    <TextView android:text="平日" android:gravity="center" android:textStyle="bold" android:padding="4dp"/>
                    <TextView android:text="土曜" android:gravity="center" android:textStyle="bold" android:padding="4dp"/>
                    <TextView
                        android:id="@+id/header_sun_ph"
                        android:text="日祝"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:padding="4dp"/>
                </TableRow>
                <TableRow>
                    <Button
                        android:id="@+id/btn_copy_to_sat"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="→土曜"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:textSize="12sp" />
                    <Button
                        android:id="@+id/btn_copy_to_sun"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="→日祝"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:textSize="12sp" />
                    <View android:layout_width="0dp" android:layout_height="0dp" />
                </TableRow>
            </TableLayout>

            <LinearLayout
                android:id="@+id/layout_holiday_warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="4dp"
                android:background="#FFF3E0"
                android:visibility="gone"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="祝日の時刻情報がありません"
                    android:textColor="#E65100"
                    android:textSize="12sp" />
                <Button
                    android:id="@+id/btn_apply_sun_to_ph"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="日曜と同じ"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textSize="12sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_add_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="行を追加"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_marginBottom="16dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_fallback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#EEEEEE"
            android:padding="8dp"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/text_fallback_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="解析できない形式のため直接編集できません" />

            <ImageButton
                android:id="@+id/btn_force_edit"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="強制的に編集する" />
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/edit_ref_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ポスト番号 (ref)"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_ref_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="保存" />

    </LinearLayout>
    </ScrollView>
</LinearLayout>
